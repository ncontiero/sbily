{
  "name": "sbily",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "description": "A Django project for a link shortener.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "build": "rspack build -c rspack/prod.config.ts",
    "build:email": "pnpm --filter=@sbily/emails run export",
    "dev": "rspack serve -c rspack/dev.config.ts",
    "dev:email": "pnpm --filter=@sbily/emails run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.8",
    "@stripe/stripe-js": "9.8.0",
    "chart.js": "4.5.1",
    "chartjs-chart-geo": "4.3.6",
    "culori": "4.0.2",
    "lucide": "1.21.0"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.3.2",
    "@rspack/cli": "2.0.8",
    "@rspack/core": "2.0.8",
    "@rspack/dev-server": "2.1.0",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "@types/culori": "4.0.1",
    "@types/node": "25.9.4",
    "eslint": "10.5.0",
    "postcss": "8.5.15",
    "postcss-loader": "8.2.1",
    "rspack-merge": "1.0.1",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "webpack-bundle-tracker": "3.2.4"
  },
  "engines": {
    "node": ">=24"
  }
}
